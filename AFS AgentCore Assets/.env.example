# ─── AFS Vision API ────────────────────────────────────────────────────────
# Base URL for the AFS Vision REST API (servicing + workflow share one host).
AFS_BASE_URL=https://afsvision.client.com/afsroot/api/v1

# HTTP Basic auth credentials for AFS Vision.
AFS_USERNAME=
AFS_PASSWORD=

# Echoed back on every request for traceability (max 24 chars).
AFS_APP_CHANNEL=AFS-MCP

# ─── Run mode ──────────────────────────────────────────────────────────────
# Default is LIVE. Flip to "true" to serve the bundled sample loan with no creds.
AFS_FIXTURE_MODE=false

# ─── Sample loan ─────────────────────────────────────────────────────────────
# The demo loan now lives in sample.config.js (edit + git push to change it).
# These env vars are OPTIONAL per-field overrides — leave them unset normally.
# AFS_SAMPLE_BANK=
# AFS_SAMPLE_OBLIGOR=
# AFS_SAMPLE_OBLIGATION=
# AFS_SAMPLE_OBLIGATION_ID=
# AFS_SAMPLE_OFFICER=
