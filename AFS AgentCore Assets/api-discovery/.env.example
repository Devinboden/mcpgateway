# Copy the two exports below into your shell before running probe.py.
# Do NOT commit real credentials. endpoints.json must never contain them.

# PowerShell:
#   $env:API_USER = "your-sandbox-username"
#   $env:API_PASS = "your-sandbox-password"

# Bash:
#   export API_USER="your-sandbox-username"
#   export API_PASS="your-sandbox-password"
