{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InvokeAfsRuntime",
      "Effect": "Allow",
      "Action": [
        "bedrock-agentcore:InvokeAgentRuntime"
      ],
      "Resource": [
        "arn:aws:bedrock-agentcore:us-east-1:111204669101:runtime/afs_mcp-F82Tf5DI8Q",
        "arn:aws:bedrock-agentcore:us-east-1:111204669101:runtime/afs_mcp-F82Tf5DI8Q/*"
      ]
    },
    {
      "Sid": "WorkloadIdentityAndTokenVault",
      "Effect": "Allow",
      "Action": [
        "bedrock-agentcore:GetWorkloadAccessToken",
        "bedrock-agentcore:GetWorkloadAccessTokenForJWT",
        "bedrock-agentcore:GetResourceOauth2Token",
        "bedrock-agentcore:GetResourceApiKey"
      ],
      "Resource": [
        "arn:aws:bedrock-agentcore:us-east-1:111204669101:workload-identity-directory/default",
        "arn:aws:bedrock-agentcore:us-east-1:111204669101:workload-identity-directory/default/workload-identity/*",
        "arn:aws:bedrock-agentcore:us-east-1:111204669101:token-vault/default/*"
      ]
    },
    {
      "Sid": "OauthProviderSecret",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": "arn:aws:secretsmanager:us-east-1:111204669101:secret:bedrock-agentcore-identity*"
    },
    {
      "Sid": "Observability",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "cloudwatch:PutMetricData"
      ],
      "Resource": "*"
    }
  ]
}
